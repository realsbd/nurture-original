# ─── Stripe Payment Gateway ────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your Stripe keys.
# Get them at: https://dashboard.stripe.com/apikeys
# NEVER commit .env.local to version control.

STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# Stripe webhook signing secret — get from Dashboard > Webhooks after you
# register your endpoint (e.g. https://yourdomain.com/api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Base URL of your app (no trailing slash)
# Local:      http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
GOOGLE_SCRIPT_SECRET=
GOOGLE_SCRIPT_URL=
RESEND_API_KEY=
EMAIL_FROM=
